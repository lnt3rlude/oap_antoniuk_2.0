{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",          /* Важливо для type: module */
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,               /* ПУНКТ 4.2: Жорстка типізація */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}